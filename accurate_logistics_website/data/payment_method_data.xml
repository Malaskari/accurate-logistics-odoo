<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- "Cash on Delivery" payment method (activated when the COD provider is
         enabled — see PaymentProvider._get_default_payment_method_codes). -->
    <record id="payment_method_cash_on_delivery" model="payment.method">
        <field name="name">Cash on Delivery</field>
        <field name="code">cash_on_delivery</field>
        <field name="sequence">1005</field>
        <field name="active">False</field>
        <field name="support_tokenization">False</field>
        <field name="support_express_checkout">False</field>
        <field name="support_refund">none</field>
    </record>

</odoo>
