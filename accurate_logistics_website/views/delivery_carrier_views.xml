<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Show the "Accurate Delivery Company" field on the Delivery Method form
       when its provider is set to Accurate Logistics. -->
  <record id="view_delivery_carrier_form_accurate" model="ir.ui.view">
    <field name="name">delivery.carrier.form.accurate</field>
    <field name="model">delivery.carrier</field>
    <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
    <field name="arch" type="xml">
      <field name="delivery_type" position="after">
        <field name="accurate_delivery_company_id"
               options="{'no_create': True}"
               invisible="delivery_type != 'accurate'"
               required="delivery_type == 'accurate'"/>
      </field>
    </field>
  </record>

</odoo>
