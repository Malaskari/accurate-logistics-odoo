<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ── List ────────────────────────────────────────────────────────────── -->
  <record id="accurate_shipment_view_list" model="ir.ui.view">
    <field name="name">accurate.shipment.list</field>
    <field name="model">accurate.shipment</field>
    <field name="arch" type="xml">
      <list string="Shipments"
            decoration-success="state == 'delivered'"
            decoration-info="state == 'sent'"
            decoration-danger="state in ('error', 'returned', 'cancelled')"
            decoration-muted="state == 'draft'">
        <header>
          <button name="action_sync_status_bulk"
                  type="object"
                  string="Sync Status"
                  class="btn-primary"
                  display="always"/>
        </header>
        <field name="name"/>
        <field name="code"/>
        <field name="ref_number"/>
        <field name="recipient_name"/>
        <field name="recipient_mobile"/>
        <field name="recipient_zone_id"/>
        <field name="delivery_company_id"/>
        <field name="api_status_name" string="API Status"/>
        <field name="fee_total" string="Total Fees"/>
        <field name="state" widget="badge"
               decoration-success="state == 'delivered'"
               decoration-info="state == 'sent'"
               decoration-danger="state in ('error', 'returned', 'cancelled')"
               decoration-warning="state == 'draft'"/>
        <field name="date"/>
      </list>
    </field>
  </record>

  <!-- ── Form ────────────────────────────────────────────────────────────── -->
  <record id="accurate_shipment_view_form" model="ir.ui.view">
    <field name="name">accurate.shipment.form</field>
    <field name="model">accurate.shipment</field>
    <field name="arch" type="xml">
      <form string="Accurate Shipment">

        <header>
          <button name="action_send_to_api"
                  string="Send to Accurate Logistics"
                  type="object"
                  class="btn-primary"
                  invisible="state in ('sent', 'delivered', 'returned', 'cancelled')"/>
          <button name="action_sync_status"
                  string="Sync Status"
                  type="object"
                  invisible="state not in ('sent', 'delivered')"/>
          <button name="action_open_cancel_wizard"
                  string="Cancel Shipment"
                  type="object"
                  class="btn-danger"
                  invisible="state not in ('sent', 'delivered')"/>
          <button name="action_mark_delivered"
                  string="Mark as Delivered (Test)"
                  type="object"
                  class="btn-warning"
                  confirm="This will create the customer invoice and register a COD payment as if Accurate Logistics had marked this shipment delivered. Continue?"
                  invisible="state != 'sent' or invoice_id != False"/>
          <button name="action_unlink_test_invoice"
                  string="Reset Delivery Test"
                  type="object"
                  confirm="Clear invoice + payment links so the shipment can be 'delivered' again? (The invoice/payment records themselves are NOT deleted.)"
                  invisible="not invoice_id"/>
          <button name="action_calculate_fees"
                  string="Calculate Fees"
                  type="object"/>
          <button name="action_open_tracking"
                  string="Track Shipment"
                  type="object"
                  invisible="not tracking_url"/>
          <button name="action_reset_to_draft"
                  string="Reset to Draft"
                  type="object"
                  invisible="state != 'error'"/>
          <field name="state" widget="statusbar"
                 statusbar_visible="draft,sent,delivered"/>
        </header>

        <sheet>

          <!-- Smart buttons -->
          <div class="oe_button_box" name="button_box">
            <button name="action_open_sale"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-shopping-cart"
                    invisible="not sale_id">
              <span class="o_stat_text">Sale Order</span>
            </button>
            <button name="action_open_picking"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-truck"
                    invisible="not picking_id">
              <span class="o_stat_text">Delivery</span>
            </button>
            <button name="action_open_invoice"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-file-text-o"
                    invisible="not invoice_id">
              <span class="o_stat_text">Invoice</span>
            </button>
          </div>

          <!-- Title -->
          <div class="oe_title">
            <h1><field name="name" readonly="1"/></h1>
          </div>

          <!-- Key info -->
          <group>
            <group string="Identity">
              <field name="code" readonly="1"/>
              <field name="ref_number"/>
              <field name="tracking_url" widget="url" readonly="1"/>
            </group>
            <group string="API Status">
              <field name="api_status_code" readonly="1"/>
              <field name="api_status_name" readonly="1"/>
              <field name="error_message" readonly="1" invisible="state != 'error'"/>
            </group>
          </group>

          <group>
            <group string="Dates">
              <field name="date"/>
              <field name="delivery_date"/>
            </group>
            <group string="Dispatch">
              <field name="delivery_company_id"/>
              <field name="service_id"/>
            </group>
          </group>

          <!-- Odoo links -->
          <group string="Linked Documents" invisible="not sale_id and not picking_id and not invoice_id">
            <group>
              <field name="sale_id" readonly="1"/>
              <field name="picking_id" readonly="1"/>
            </group>
            <group>
              <field name="invoice_id" readonly="1"/>
              <field name="payment_id" readonly="1"/>
              <field name="expense_move_id" readonly="1"
                     invisible="not expense_move_id"/>
            </group>
          </group>

          <!-- Reason (cancellation / failed-delivery / return) -->
          <group string="Reason"
                 invisible="not cancellation_reason_id and not cancellation_notes">
            <field name="cancellation_reason_id" readonly="1"/>
            <field name="cancellation_notes" readonly="1"/>
          </group>

          <notebook>

            <!-- Tab 1: Recipient -->
            <page string="Recipient" name="recipient">
              <group>
                <group string="Contact">
                  <field name="recipient_name"/>
                  <field name="recipient_phone"/>
                  <field name="recipient_mobile"/>
                  <field name="recipient_address"/>
                </group>
                <group string="Zone">
                  <field name="recipient_zone_id"
                         options="{'no_create': True}"
                         readonly="not delivery_company_id"
                         placeholder="Pick a Delivery Company first"/>
                  <field name="recipient_subzone_id"
                         options="{'no_create': True}"
                         readonly="not recipient_zone_id"
                         placeholder="Pick a Zone first"/>
                  <field name="recipient_latitude"/>
                  <field name="recipient_longitude"/>
                </group>
              </group>
            </page>

            <!-- Tab 2: Sender -->
            <page string="Sender" name="sender">
              <group>
                <group string="Contact">
                  <field name="sender_name"/>
                  <field name="sender_phone"/>
                  <field name="sender_mobile"/>
                  <field name="sender_address"/>
                  <field name="sender_postal_code"/>
                </group>
                <group string="Zone">
                  <field name="sender_zone_id"
                         options="{'no_create': True}"
                         readonly="not delivery_company_id"
                         placeholder="Pick a Delivery Company first"/>
                  <field name="sender_subzone_id"
                         options="{'no_create': True}"
                         readonly="not sender_zone_id"
                         placeholder="Pick a Zone first"/>
                </group>
              </group>
            </page>

            <!-- Tab 3: Shipment Details -->
            <page string="Details" name="details">
              <group>
                <group string="Classification">
                  <field name="type_code"/>
                  <field name="payment_type_code"/>
                  <field name="price_type_code"/>
                  <field name="openable_code"/>
                </group>
                <group string="Physical">
                  <field name="weight"/>
                  <field name="pieces_count"/>
                  <field name="return_pieces_count"/>
                  <field name="price"/>
                </group>
              </group>
              <group string="Box Dimensions">
                <group>
                  <field name="size_length"/>
                  <field name="size_width"/>
                  <field name="size_height"/>
                </group>
              </group>
              <group string="Notes">
                <field name="description" colspan="2"/>
                <field name="notes" colspan="2"/>
              </group>
            </page>

            <!-- Tab 4: Products -->
            <page string="Products" name="products">
              <field name="product_ids">
                <list editable="bottom">
                  <field name="sequence" widget="handle"/>
                  <field name="name"/>
                  <field name="quantity"/>
                  <field name="price"/>
                </list>
              </field>
            </page>

            <!-- Tab 5: Fees -->
            <page string="Fees" name="fees">
              <group string="Fee Breakdown (from API)">
                <group>
                  <field name="fee_amount" readonly="1"/>
                  <field name="fee_delivery" readonly="1"/>
                </group>
                <group>
                  <field name="fee_collection" readonly="1"/>
                  <field name="fee_total" readonly="1"/>
                </group>
              </group>
            </page>

          </notebook>
        </sheet>

        <chatter/>

      </form>
    </field>
  </record>

  <!-- ── Search ──────────────────────────────────────────────────────────── -->
  <record id="accurate_shipment_view_search" model="ir.ui.view">
    <field name="name">accurate.shipment.search</field>
    <field name="model">accurate.shipment</field>
    <field name="arch" type="xml">
      <search string="Accurate Shipments">
        <field name="name" string="Reference"/>
        <field name="code" string="Shipment Code"/>
        <field name="ref_number"/>
        <field name="recipient_name"/>
        <field name="recipient_mobile"/>
        <field name="delivery_company_id"/>
        <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
        <filter string="Sent" name="sent" domain="[('state','=','sent')]"/>
        <filter string="Delivered" name="delivered" domain="[('state','=','delivered')]"/>
        <filter string="Returned" name="returned" domain="[('state','=','returned')]"/>
        <filter string="Cancelled" name="cancelled" domain="[('state','=','cancelled')]"/>
        <filter string="Error" name="error" domain="[('state','=','error')]"/>
        <filter string="Not Invoiced" name="not_invoiced"
                domain="[('invoice_id','=',False),('state','=','sent')]"/>
        <group>
          <filter string="Delivery Company" name="by_company"
                  context="{'group_by': 'delivery_company_id'}"/>
          <filter string="Status" name="by_status"
                  context="{'group_by': 'api_status_code'}"/>
          <filter string="State" name="by_state"
                  context="{'group_by': 'state'}"/>
        </group>
      </search>
    </field>
  </record>

  <!-- ── Action ──────────────────────────────────────────────────────────── -->
  <record id="accurate_shipment_action" model="ir.actions.act_window">
    <field name="name">Shipments</field>
    <field name="res_model">accurate.shipment</field>
    <field name="view_mode">list,form</field>
    <field name="search_view_id" ref="accurate_shipment_view_search"/>
  </record>

</odoo>
