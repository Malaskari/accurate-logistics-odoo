<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Add the Delivery Company logo + Accurate shipment code & scannable
       barcode to the Delivery Slip report, just under the document title.
       The company is resolved from the picking's direct link, else from the
       linked shipment / Sale Order, so it shows on every picking step. -->
  <template id="report_delivery_document_accurate_barcode"
            inherit_id="stock.report_delivery_document">
    <xpath expr="//div[@id='informations']" position="before">
      <div t-if="o.accurate_shipment_code"
           class="text-center mb-3"
           name="accurate_shipment_barcode">
        <div><strong>Accurate Shipment</strong></div>
        <img t-att-src="'/report/barcode/Code128/' + o.accurate_shipment_code"
             style="width:320px;height:60px;"
             alt="Shipment Barcode"/>
        <div style="font-size:14px;letter-spacing:2px;">
          <span t-out="o.accurate_shipment_code"/>
        </div>
      </div>
    </xpath>

    <!-- Extra meta fields in the info block: Salesperson (from the linked Sale
         Order), recipient Zone + Sub-zone, and the customer phone. Sources are
         resolved robustly: zone/sub-zone fall back to the linked shipment, and
         the phone uses the shipment's recipient_phone/recipient_mobile (Char,
         present in Odoo 18 AND 19) rather than partner.mobile (removed in 19). -->
    <xpath expr="//div[@id='informations']" position="inside">
      <t t-set="al_ship" t-value="o._accurate_resolve_shipment()"/>
      <t t-set="al_zone" t-value="o.accurate_recipient_zone_id or al_ship.recipient_zone_id"/>
      <t t-set="al_subzone" t-value="o.accurate_recipient_subzone_id or al_ship.recipient_subzone_id"/>
      <t t-set="al_phone" t-value="o.partner_id.phone or al_ship.recipient_phone or al_ship.recipient_mobile"/>
      <t t-set="al_currency" t-value="o.sale_id.currency_id or o.company_id.currency_id"/>

      <div class="col-auto" name="div_accurate_salesperson" t-if="o.accurate_salesperson_id">
        <strong>Salesperson:</strong>
        <p class="m-0" t-out="o.accurate_salesperson_id.name"/>
      </div>
      <div class="col-auto" name="div_accurate_zone" t-if="al_zone">
        <strong>Zone:</strong>
        <p class="m-0" t-out="al_zone.name"/>
      </div>
      <div class="col-auto" name="div_accurate_subzone" t-if="al_subzone">
        <strong>Sub-zone:</strong>
        <p class="m-0" t-out="al_subzone.name"/>
      </div>
      <div class="col-auto" name="div_accurate_phone" t-if="al_phone">
        <strong>Phone:</strong>
        <p class="m-0" t-out="al_phone"/>
      </div>
      <div class="col-auto" name="div_accurate_delivery_fees" t-if="al_ship">
        <strong>Delivery Fees:</strong>
        <p class="m-0" t-out="al_ship.fee_delivery"
           t-options="{'widget': 'monetary', 'display_currency': al_currency}"/>
      </div>
      <div class="col-auto" name="div_accurate_so_total" t-if="o.sale_id">
        <strong>Order Total:</strong>
        <p class="m-0" t-out="o.sale_id.amount_total"
           t-options="{'widget': 'monetary', 'display_currency': o.sale_id.currency_id}"/>
      </div>
    </xpath>
  </template>

</odoo>
