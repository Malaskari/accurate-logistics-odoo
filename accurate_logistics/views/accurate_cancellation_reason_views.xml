<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="accurate_cancellation_reason_view_list" model="ir.ui.view">
    <field name="name">accurate.cancellation.reason.list</field>
    <field name="model">accurate.cancellation.reason</field>
    <field name="arch" type="xml">
      <list string="Cancellation Reasons" editable="bottom">
        <field name="sequence" widget="handle"/>
        <field name="api_id"/>
        <field name="code"/>
        <field name="name"/>
        <field name="active" widget="boolean_toggle"/>
      </list>
    </field>
  </record>

  <record id="accurate_cancellation_reason_view_form" model="ir.ui.view">
    <field name="name">accurate.cancellation.reason.form</field>
    <field name="model">accurate.cancellation.reason</field>
    <field name="arch" type="xml">
      <form string="Cancellation Reason">
        <sheet>
          <div class="oe_title"><h1><field name="name"/></h1></div>
          <group>
            <group>
              <field name="api_id" readonly="1"/>
              <field name="code"/>
              <field name="type_code"/>
            </group>
            <group>
              <field name="active"/>
              <field name="sequence"/>
            </group>
          </group>
          <field name="description" placeholder="Optional description…"/>
        </sheet>
      </form>
    </field>
  </record>

  <record id="accurate_cancellation_reason_action" model="ir.actions.act_window">
    <field name="name">Cancellation Reasons</field>
    <field name="res_model">accurate.cancellation.reason</field>
    <field name="view_mode">list,form</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">No cancellation reasons yet.</p>
      <p>Open a Delivery Company and click <b>Sync Cancellation Reasons</b> to pull them from the Accurate Logistics API.</p>
    </field>
  </record>

</odoo>
