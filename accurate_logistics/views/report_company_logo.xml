<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Show the Delivery Company logo at the TOP-RIGHT of the report header,
       beside the company address block, on EVERY standard document layout
       (Light/Standard, Boxed, Bold, Striped, Folder, Wave, Bubble).

       The header template is chosen by the company's "Document Layout" setting,
       so the logo MUST be injected into each layout — otherwise switching the
       layout (e.g. Bold -> Wave) makes the delivery logo disappear.

       Each block is guarded so it only renders for records that actually carry
       a delivery company (sale.order / account.move / stock.picking). For a
       picking without the field set directly, it resolves via the linked
       shipment / Sale Order. `o` is always defined here (web.external_layout
       sets it from `doc`).

       NOTE: do NOT use hasattr() in these expressions — QWeb's safe_eval does
       not expose hasattr, so it evaluates to None and calling it raises
       "'NoneType' object is not callable", breaking EVERY PDF. We use the
       `'field' in o._fields` membership test and an `o._name` model check
       instead. -->

  <template id="external_layout_standard_accurate_logo"
            inherit_id="web.external_layout_standard">
    <xpath expr="//ul[@name='company_address_list']" position="before">
      <t t-if="o and 'accurate_delivery_company_id' in o._fields">
        <t t-set="al_dc" t-value="o.accurate_delivery_company_id"/>
        <t t-if="not al_dc and o._name == 'stock.picking'"
           t-set="al_dc" t-value="o._accurate_resolve_shipment().delivery_company_id"/>
        <img t-if="al_dc and al_dc.logo"
             class="o_company_logo_big float-end"
             t-att-src="image_data_uri(al_dc.logo)"
             style="max-height:130px;max-width:260px;"
             alt="Delivery Company Logo"/>
      </t>
    </xpath>
  </template>

