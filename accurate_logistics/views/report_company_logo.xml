<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Delivery Company logo, top-right of the Sale Order PDF (next to the
       company logo in the header). -->
  <template id="report_saleorder_accurate_logo"
            inherit_id="sale.report_saleorder_document">
    <xpath expr="//div[hasclass('page')]/*[1]" position="before">
      <img t-if="doc.accurate_delivery_company_id.logo"
           t-att-src="image_data_uri(doc.accurate_delivery_company_id.logo)"
           class="float-end"
           style="max-height:55px;max-width:160px;"
           alt="Delivery Company Logo"/>
    </xpath>
  </template>

  <!-- Delivery Company logo, top-right of the Invoice PDF. -->
  <template id="report_invoice_accurate_logo"
            inherit_id="account.report_invoice_document">
    <xpath expr="//div[hasclass('page')]/*[1]" position="before">
      <img t-if="o.accurate_delivery_company_id.logo"
           t-att-src="image_data_uri(o.accurate_delivery_company_id.logo)"
           class="float-end"
           style="max-height:55px;max-width:160px;"
           alt="Delivery Company Logo"/>
    </xpath>
  </template>

</odoo>
