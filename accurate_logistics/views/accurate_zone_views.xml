<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- List -->
  <record id="accurate_zone_view_list" model="ir.ui.view">
    <field name="name">accurate.zone.list</field>
    <field name="model">accurate.zone</field>
    <field name="arch" type="xml">
      <list string="Zones">
        <field name="name"/>
        <field name="is_subzone"/>
        <field name="parent_id"/>
        <field name="child_count" string="Sub-zones"/>
        <field name="api_id"/>
      </list>
    </field>
  </record>

  <!-- Form -->
  <record id="accurate_zone_view_form" model="ir.ui.view">
    <field name="name">accurate.zone.form</field>
    <field name="model">accurate.zone</field>
    <field name="arch" type="xml">
      <form string="Zone">
        <header>
          <button name="action_sync_my_subzones"
                  string="Sync Sub-zones from API"
                  type="object"
                  class="btn-primary"
                  invisible="is_subzone"/>
        </header>
        <sheet>
          <div class="oe_button_box" name="button_box">
            <button name="action_view_subzones"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-map-marker"
                    invisible="is_subzone">
              <field name="child_count" widget="statinfo" string="Sub-zones"/>
            </button>
          </div>
          <group>
            <group>
              <field name="name"/>
              <field name="is_subzone"/>
              <field name="api_id"
                     help="Filled automatically when synced from API. Leave empty for manually-created zones."/>
              <field name="in_price_list" invisible="not is_subzone"/>
            </group>
            <group>
              <field name="parent_id"
                     invisible="not is_subzone"
                     required="is_subzone"
                     options="{'no_create': True}"/>
            </group>
          </group>
          <group string="Delivery Companies"
                 help="Pick the delivery companies this zone belongs to. The zone will appear in the recipient zone / sub-zone dropdowns on shipments + sale orders + pickings for those companies.">
            <field name="delivery_company_ids"
                   widget="many2many_tags"
                   nolabel="1"
                   options="{'no_create': True}"/>
          </group>
          <group string="Shipping Services"
                 help="In Accurate Logistics, available zones differ per service price list. Link this zone to the specific shipping services that include it.">
            <field name="service_ids"
                   widget="many2many_tags"
                   nolabel="1"
                   options="{'no_create': True}"
                   domain="[('company_id', 'in', delivery_company_ids)]"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Action – Zones -->
  <record id="accurate_zone_action" model="ir.actions.act_window">
    <field name="name">Zones</field>
    <field name="res_model">accurate.zone</field>
    <field name="view_mode">list,form</field>
    <field name="domain">[('is_subzone', '=', False)]</field>
    <field name="context">{'default_is_subzone': False}</field>
  </record>

  <!-- Action – Sub-zones -->
  <record id="accurate_subzone_action" model="ir.actions.act_window">
    <field name="name">Sub-zones</field>
    <field name="res_model">accurate.zone</field>
    <field name="view_mode">list,form</field>
    <field name="domain">[('is_subzone', '=', True)]</field>
    <field name="context">{'default_is_subzone': True}</field>
  </record>

</odoo>
